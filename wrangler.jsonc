// wrangler.jsonc — mypofo 部署到 Cloudflare Workers (临时/正式账号通用)
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mypofo",
  "compatibility_date": "2026-06-01",
  "main": "src/worker.js",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
